{
  "name": "Java Dev Container",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "workspaceFolder": "/workspace",

  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "source=maven-cache,target=/home/vscode/.m2,type=volume"
  ],

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.java",
        "vscjava.vscode-java-pack"
      ]
    }
  }
}
